{
    "assistant": {
        "chat_completion_timeout_sec": 300
    },
    "embedding": {
        "max_text_length": 1500
    },
    "indexing": {
        "chunk_overlap": 200,
        "chunk_size": 1000,
        "chunking_strategy": "tree-sitter",
        "ignored_directories": [
            "build",
            ".git",
            ".vscode",
            "CMakeFiles"
        ],
        "ignored_extensions": [
            ".exe",
            ".obj",
            ".pdb",
            ".ilk",
            ".sln",
            ".vcxproj",
            ".filters",
            ".user",
            ".recipe",
            ".tlog",
            ".lastbuildstate",
            ".bin",
            ".stamp",
            ".cmake",
            ".json",
            ".log"
        ],
        "ignored_files": [
            ".gitignore"
        ],
        "top_k_results": 3
    },
    "server": {
        "host": "localhost",
        "port": 8080,
        "retry_count": 3,
        "retry_delay_ms": 500
    }
}